
gitignore = '''# DISTRIKIA - Archivos a ignorar

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Streamlit
.streamlit/secrets.toml
!/.streamlit/config.toml
.streamlit/credentials.json
# Jupyter Notebook
.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Datos locales (no subir datos reales)
*.csv
*.xlsx
!requirements.txt

# Logs
*.log
'''

with open('/mnt/kimi/output/.gitignore', 'w') as f:
    f.write(gitignore)

print("✅ .gitignore generado")
